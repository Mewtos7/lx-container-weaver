# LX Container Weaver — environment variable template
# Copy this file to .env and fill in the required values.
# Never commit .env to source control.

# ── HTTP server ────────────────────────────────────────────────────────────────

# Address (host:port) the HTTP server binds to.
# Default: :8080
HTTP_ADDR=:8080

# ── Database ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
# Example: postgres://user:password@localhost:5432/weaver?sslmode=disable
DATABASE_URL=

# ── Authentication (ADR-003) ───────────────────────────────────────────────────

# Comma-separated list of bcrypt-hashed API keys for protected endpoints.
# Each client is issued a unique raw key; only the bcrypt hash is stored here.
# Required — the server will refuse to start if this is empty.
#
# Generate a hash for a new key with:
#   python3 -c "import bcrypt,secrets; k=secrets.token_urlsafe(32); h=bcrypt.hashpw(k.encode(), bcrypt.gensalt()).decode(); print('key:', k, '\nhash:', h)"
# or with htpasswd (Apache utils):
#   htpasswd -bnBC 12 "" <raw-key> | tr -d ':\n'
# or with the Go bcrypt package:
#   go run tools/gen-api-key/main.go
#
# Example (do NOT use this hash in production):
# API_KEYS=$2a$12$examplehashvalue...

API_KEYS=

# ── Logging ────────────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# ── Reconciliation ─────────────────────────────────────────────────────────────

# How often the orchestration loop runs per cluster (Go duration string).
# Default: 60s
RECONCILE_INTERVAL=60s

# Maximum time to wait for in-flight requests during graceful shutdown.
# Default: 30s
SHUTDOWN_TIMEOUT=30s
